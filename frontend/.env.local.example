# Template for the local-only env overrides used by Path B in
# docs/testing-on-phone.md (tunneled phone testing).
#
# To use:
#   cp .env.local.example .env.local
#
# The copied file (`.env.local`) is gitignored (matches *.local).
#
# Empty VITE_BACKEND_URL forces the API client to build relative URLs,
# which routes through the Vite proxy in vite.config.local.ts.
VITE_BACKEND_URL=
