# syntax=docker/dockerfile:1
# Development image for The Scribe backend. The production image
# (`Dockerfile`) strips development gems and locks RAILS_ENV=production,
# so it can't be reused for `docker compose up`.
#
# This image installs the full bundle (including the development and
# test groups) and expects the application source to be bind-mounted in
# at /rails by docker-compose, so code edits hot-reload without a
# rebuild.

ARG RUBY_VERSION=4.0.3
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle" \
    BINDING="0.0.0.0"

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libpq-dev \
      libvips \
      libyaml-dev \
      pkg-config && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Pre-install gems so the first `up` has a warm bundle. The bundle lives
# in a named volume (see docker-compose.yml), so this layer is only used
# the first time the volume is created.
COPY Gemfile Gemfile.lock ./
RUN bundle install

EXPOSE 3000

CMD ["bin/rails", "server", "-b", "0.0.0.0", "-p", "3000"]
